<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="false">
        <!-- Firebase domains -->
        <domain includeSubdomains="true">firebase.googleapis.com</domain>
        <domain includeSubdomains="true">firestore.googleapis.com</domain>
        <domain includeSubdomains="true">firebaseapp.com</domain>
        <domain includeSubdomains="true">firebasestorage.app</domain>
        
        <!-- Google APIs -->
        <domain includeSubdomains="true">googleapis.com</domain>
        <domain includeSubdomains="true">maps.googleapis.com</domain>
        <domain includeSubdomains="true">google.com</domain>
        
        <!-- Cloudinary -->
        <domain includeSubdomains="true">cloudinary.com</domain>
        <domain includeSubdomains="true">res.cloudinary.com</domain>
        
        <!-- Your API domains (add your own if any) -->
        <domain includeSubdomains="true">nexordis.com</domain>
    </domain-config>
    
    <!-- Base configuration for all other domains -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system certificate authorities -->
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>