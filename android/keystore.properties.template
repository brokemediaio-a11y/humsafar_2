# Keystore properties for release signing
# Copy this file to keystore.properties and fill in your actual values
# DO NOT commit keystore.properties to version control

storePassword=your_keystore_password
keyPassword=your_key_password
keyAlias=your_key_alias
storeFile=../path/to/your/keystore.jks

# Example:
# storePassword=myStorePassword123
# keyPassword=myKeyPassword123
# keyAlias=humsafar-key
# storeFile=../humsafar-keystore.jks